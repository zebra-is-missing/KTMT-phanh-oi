# CÁC CHƯƠNG TRÌNH CON PHỤ (HELPER FUNCTIONS)
# =================================================================

# --- Hàm xuất chuỗi ký tự (String) ra công cụ MMIO Display Tool ---
mmio_print_string:
    mv t2, a0                   # Lưu địa chỉ gốc của chuỗi từ tham số a0 sang thanh ghi t2
mmio_char_loop:
    lbu t3, 0(t2)               # Đọc 1 byte ký tự từ ô nhớ t2 trỏ tới lưu vào t3
    beqz t3, mmio_print_end     # Nếu t3 == 0 (Gặp ký tự rỗng '\0' kết thúc chuỗi), kết thúc hàm

wait_display_ready:
    li t0, MMIO_DCTRL           # Tải địa chỉ điều khiển màn hình hiển thị MMIO vào t0
    lw t1, 0(t0)                # Đọc trạng thái thanh ghi hiển thị vào t1
    andi t1, t1, 1              # Trích xuất bit Ready (bit số 0) của Display Control
    beqz t1, wait_display_ready # Nếu bit Ready == 0 (màn hình đang bận), lặp lại vòng chờ polling

    li t0, MMIO_DDATA           # Tải địa chỉ dữ liệu màn hình hiển thị MMIO vào t0
    sw t3, 0(t0)                # Ghi mã ký tự từ t3 vào thanh ghi dữ liệu hiển thị MMIO_DDATA để xuất chữ

    addi t2, t2, 1              # Tăng địa chỉ con trỏ chuỗi t2 thêm 1 byte để chỉ tới ký tự tiếp theo
    j mmio_char_loop            # Lặp lại vòng xử lý ký tự tiếp theo
    
# --- Hàm xuất một ký tự đơn (Char) ra công cụ MMIO Display Tool ---
mmio_print_char:
wait_mmio_char:
    li t0, MMIO_DCTRL           # Tải địa chỉ điều khiển màn hình hiển thị MMIO vào t0
    lw t1, 0(t0)                # Đọc trạng thái thanh ghi hiển thị vào t1
    andi t1, t1, 1              # Trích xuất kiểm tra bit Ready (bit số 0)
    beqz t1, wait_mmio_char     # Nếu bit Ready == 0 (màn hình bận), tiếp tục vòng chờ polling

    li t0, MMIO_DDATA           # Tải địa chỉ dữ liệu màn hình hiển thị MMIO vào t0
    sw a0, 0(t0)                # Ghi mã ký tự truyền vào từ tham số a0 vào ô nhớ dữ liệu MMIO để hiển thị
    ret                         # Quay trở về nơi gọi hàm

mmio_print_end:
    ret                         # Quay trở về nơi gọi hàm hiển thị chuỗi

# --- Hàm tách và xuất số nguyên (Integer) ra công cụ MMIO Display Tool ---
mmio_print_int:
    addi sp, sp, -20            # Mở rộng bộ nhớ vùng đệm Stack (Cấp phát 20 bytes)
    sw ra, 16(sp)               # Lưu địa chỉ trở về ra vào Stack để bảo toàn cấu trúc hàm
    sw t0, 12(sp)               # Lưu giá trị thanh ghi tạm t0 vào Stack
    sw t1, 8(sp)                # Lưu giá trị thanh ghi tạm t1 vào Stack
    sw t2, 4(sp)                # Lưu giá trị thanh ghi tạm t2 vào Stack
    sw s6, 0(sp)                # Lưu giá trị thanh ghi an toàn s6 vào Stack
    
    mv s6, sp                   # Ghi nhận và giữ lại vị trí đáy của vùng đệm stack hiện thời vào s6

    li t0, 10                   # Gán giá trị hằng số t0 = 10 để thực hiện phép toán hệ thập phân
    li s7, 0                    # Khởi tạo biến đếm số lượng chữ số s7 = 0

convert_loop:
    rem t2, a0, t0              # t2 = a0 % 10 (Lấy ra chữ số ở hàng đơn vị cuối cùng của số nguyên)
    addi t2, t2, '0'            # Chuyển đổi giá trị số đơn lẻ đó sang ký tự mã ASCII tương ứng

    addi sp, sp, -4             # Đẩy con trỏ Stack lên 4 bytes để tạo không gian lưu chữ số
    sw t2, 0(sp)                # Cất ký tự chữ số vừa chuyển đổi vào trong Stack

    addi s7, s7, 1              # Tăng biến đếm tổng số lượng chữ số s7 lên thêm 1 đơn vị

    div a0, a0, t0              # a0 = a0 / 10 (Loại bỏ chữ số hàng đơn vị vừa lấy để xét chữ số tiếp theo)
    bnez a0, convert_loop       # Nếu số nguyên a0 vẫn còn giá trị (!= 0), tiếp tục vòng lặp tách số

print_digits:
    beqz s7, restore_stack      # Nếu s7 == 0 (Đã in ra hết tất cả các chữ số đã tách), nhảy sang khôi phục Stack

    lw a0, 0(sp)                # Đọc chữ số từ đỉnh của vùng đệm Stack ra thanh ghi tham số a0
    addi sp, sp, 4              # Thu nhỏ con trỏ Stack về lại 4 bytes (Pop phần tử)

    jal ra, mmio_print_char     # Gọi hàm xuất ký tự vừa lấy ra màn hình MMIO Display

    addi s7, s7, -1             # Giảm số lượng chữ số cần in còn lại đi 1 đơn vị (s7 = s7 - 1)
    j print_digits              # Tiếp tục lặp để in chữ số tiếp theo ra màn hình

restore_stack:
    mv sp, s6                   # Khôi phục con trỏ Stack về đúng vị trí đáy ban đầu lưu ở s6

    lw s6, 0(sp)                # Phục hồi giá trị gốc ban đầu của thanh ghi s6 từ Stack
    lw t2, 4(sp)                # Phục hồi giá trị gốc ban đầu của thanh ghi t2 từ Stack
    lw t1, 8(sp)                # Phục hồi giá trị gốc ban đầu của thanh ghi t1 từ Stack
    lw t0, 12(sp)               # Phục hồi giá trị gốc ban đầu của thanh ghi t0 từ Stack
    lw ra, 16(sp)               # Phục hồi địa chỉ trả về ra gốc ban đầu từ Stack

    addi sp, sp, 20             # Thu hồi hoàn toàn 20 bytes bộ nhớ vùng đệm Stack đã cấp phát
    ret                         # Trở về hàm gọi trước đó

# --- Thuật toán Fisher-Yates Shuffle: Xáo ngẫu nhiên vị trí các câu hỏi câu trả lời ---
shuffle_questions:

    # --- Tạo hạt giống ngẫu nhiên (Seed RNG) ---
    li a7, 30                   # Gán mã dịch vụ ecall = 30 (Lấy thời gian hệ thống hiện tại - System Time)
    ecall                       # Thực thi, kết quả trả về thời gian nằm ở cặp thanh ghi a0, a1
    
    mv a1, a0                   # Lấy thời gian từ a0 làm tham số giá trị hạt giống cho a1
    li a0, 0                    # Thiết lập mã định danh bộ sinh số ID = 0 vào thanh ghi a0
    li a7, 40                   # Gán mã dịch vụ ecall = 40 (Thiết lập hạt giống ngẫu nhiên - Set Seed)
    ecall                       # Kích hoạt thiết lập sinh số ngẫu nhiên ngầm định

    lw t0, num_questions        # Load tổng số lượng câu hỏi (20) từ ô nhớ num_questions vào t0
    addi t0, t0, -1             # Đặt chỉ số chạy vòng lặp i = num_questions - 1 (t0 = 19)

shuffle_loop:
    blez t0, shuffle_end        # Vòng lặp chạy lùi: Nếu i (t0) <= 0 thì kết thúc quá trình xáo trộn câu hỏi

    # --- Sinh ra chỉ số ngẫu nhiên j nằm trong khoảng [0 .. i] ---
    li a0, 0                    # Đặt mã định danh bộ sinh ngẫu nhiên ID = 0 vào a0
    addi a1, t0, 1              # Giới hạn trên mong muốn a1 = t0 + 1 (Khoảng sinh ngẫu nhiên từ 0 đến dưới a1)
    li a7, 42                   # Gán mã dịch vụ ecall = 42 (Sinh số nguyên ngẫu nhiên có phạm vi - Rand Int Range)
    ecall                       # Kết quả số ngẫu nhiên j trả về nằm ở thanh ghi a0

    mv t1, a0                   # Lưu số ngẫu nhiên j vừa sinh từ thanh ghi a0 sang thanh ghi t1

    # --- Hoán đổi giá trị phần tử mảng câu hỏi: questions_array[i] <-> questions_array[j] ---
    la t2, questions_array      # Tải địa chỉ cơ sở của mảng questions_array vào t2

    slli t3, t0, 2              # t3 = i * 4 (Tính khoảng lệch bytes offset cho phần tử thứ i)
    add t4, t2, t3              # t4 = Địa chỉ thực tế của phần tử questions_array[i]

    slli t5, t1, 2              # t5 = j * 4 (Tính khoảng lệch bytes offset cho phần tử thứ j ngẫu nhiên)
    add t6, t2, t5              # t6 = Địa chỉ thực tế của phần tử questions_array[j]

    lw a2, 0(t4)                # Đọc địa chỉ chuỗi câu hỏi tại vị trí i lưu vào thanh ghi temporary a2
    lw a3, 0(t6)                # Đọc địa chỉ chuỗi câu hỏi tại vị trí j lưu vào thanh ghi temporary a3

    sw a3, 0(t4)                # Ghi giá trị câu hỏi j vào vị trí ô nhớ của câu hỏi i
    sw a2, 0(t6)                # Ghi giá trị câu hỏi i vào vị trí ô nhớ của câu hỏi j

    # --- Hoán đổi giá trị phần tử mảng đáp án song song: answers_array[i] <-> answers_array[j] ---
    la t2, answers_array        # Tải địa chỉ cơ sở của mảng dữ liệu đáp án answers_array vào t2

    add t4, t2, t0              # t4 = Địa chỉ thực tế phần tử answers_array[i] (Mỗi phần tử rộng đúng 1 byte)
    add t6, t2, t1              # t6 = Địa chỉ thực tế phần tử answers_array[j] (Mỗi phần tử rộng đúng 1 byte)

    lbu a2, 0(t4)               # Đọc 1 byte đáp án tại vị trí i lưu vào thanh ghi a2
    lbu a3, 0(t6)               # Đọc 1 byte đáp án tại vị trí j lưu vào thanh ghi a3

    sb a3, 0(t4)                # Ghi giá trị đáp án j thế vào ô nhớ của đáp án i
    sb a2, 0(t6)                # Ghi giá trị đáp án i thế vào ô nhớ của đáp án j

    addi t0, t0, -1             # Giảm chỉ số vòng lặp i đi 1 đơn vị (i--) để xét cặp phần tử tiếp theo
    j shuffle_loop              # Tiếp tục quay lại thực hiện vòng lặp xáo trộn phần tử tiếp theo

shuffle_end:
    ret                         # Hoàn thành thuật toán hoán đổi xáo trộn, quay về chương trình gọi

# --- Hàm hiển thị số giây đếm ngược lên 2 Bộ Đèn LED 7 Đoạn ---
display_countdown:
    li t0, 10                   # Tải hằng số chia t0 = 10 vào để thực hiện bóc tách hai chữ số

    div t1, a0, t0              # t1 = a0 / 10 (Lấy ra chữ số ở hàng chục của thời gian giây truyền vào)
    rem t2, a0, t0              # t2 = a0 % 10 (Lấy ra chữ số ở hàng đơn vị của thời gian giây truyền vào)

    la t3, digit_table          # Tải địa chỉ cơ sở của bảng mã Hex hiển thị LED (digit_table) vào t3

    add t4, t3, t1              # t4 = Vị trí chứa mã Hex của chữ số hàng chục trong bảng mã
    lbu t5, 0(t4)               # Đọc mã hiển thị LED tương ứng của chữ số hàng chục vào thanh ghi t5

    add t4, t3, t2              # t4 = Vị trí chứa mã Hex của chữ số hàng đơn vị trong bảng mã
    lbu t6, 0(t4)               # Đọc mã hiển thị LED tương ứng của chữ số hàng đơn vị vào thanh ghi t6

    li t4, DIGIT_LEFT           # Tải địa chỉ cổng phần cứng điều khiển LED bên trái vào t4
    sb t5, 0(t4)                # Ghi mã Hex t5 vào cổng phần cứng để hiển thị chữ số hàng chục lên LED trái

    li t4, DIGIT_RIGHT          # Tải địa chỉ cổng phần cứng điều khiển LED bên phải vào t4
    sb t6, 0(t4)                # Ghi mã Hex t6 vào cổng phần cứng để hiển thị chữ số hàng đơn vị lên LED phải

    ret                         # Quay trở về nơi gọi hàm đếm ngược hiển thị

# Hàm thoát chương trình an toàn
exit_program:
    li a7, 10                   # Gán mã dịch vụ ecall = 10 (Hàm dừng và thoát chương trình - Terminate/Exit)
    ecall                       # Thực thi lệnh gọi hệ thống để tắt chương trình mô phỏng một cách an toàn
