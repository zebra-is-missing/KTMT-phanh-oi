# --- Khai báo các hằng số địa chỉ MMIO (Memory-Mapped I/O) ---
.eqv MMIO_CTRL  0xFFFF0000     # Địa chỉ thanh ghi trạng thái (Control) của Keyboard
.eqv MMIO_DATA  0xFFFF0004     # Địa chỉ thanh ghi dữ liệu (Data) của Keyboard
.eqv MMIO_DCTRL 0xFFFF0008     # Địa chỉ thanh ghi trạng thái (Control) của Display (Màn hình)
.eqv MMIO_DDATA 0xFFFF000C     # Địa chỉ thanh ghi dữ liệu (Data) của Display (Màn hình)
.eqv DIGIT_LEFT   0xFFFF0011   # Địa chỉ điều khiển đèn LED 7 đoạn bên trái
.eqv DIGIT_RIGHT  0xFFFF0010   # Địa chỉ điều khiển đèn LED 7 đoạn bên phải

