# =================================================================
# HÀM CHÍNH (MAIN LOOP) - HIỂN THỊ MENU VÀ XỬ LÝ LỰA CHỌN
# =================================================================
main:
    # --- Hiển thị tiêu đề Menu ---
    la a0, menu_title           # Tải địa chỉ chuỗi menu_title vào a0
    li a7, 4                    # Gán mã dịch vụ ecall = 4 (In chuỗi ký tự - Print String)
    ecall                       # Thực hiện gọi hệ thống để in tiêu đề

    # --- Hiển thị lựa chọn 1 ---
    la a0, menu_opt1            # Tải địa chỉ chuỗi menu_opt1 vào a0
    ecall                       # Thực hiện in lựa chọn 1

    # --- Hiển thị lựa chọn 2 ---
    la a0, menu_opt2            # Tải địa chỉ chuỗi menu_opt2 vào a0
    ecall                       # Thực hiện in lựa chọn 2

    # --- Hiển thị dòng yêu cầu nhập ---
    la a0, menu_choos           # Tải địa chỉ chuỗi menu_choos vào a0
    ecall                       # Thực hiện in dòng yêu cầu nhập

    # --- Đọc lựa chọn từ bàn phím (Xác thực dữ liệu) ---
    li a7, 12                   # Gán mã dịch vụ ecall = 12 (Đọc 1 ký tự từ bàn phím - Read Char)
    ecall                       # Thực hiện ecall, ký tự nhập về sẽ nằm ở thanh ghi a0
    mv t0, a0                   # Di chuyển (sao chép) ký tự vừa nhập từ a0 sang thanh ghi t0

    # --- Kiểm tra nếu người dùng chọn '1' ---
    li t1, '1'                  # Tải ký tự mã ASCII của '1' vào t1
    beq t0, t1, start_quiz      # Nếu t0 == t1 ('1'), nhảy đến nhãn start_quiz để bắt đầu thi

    # --- Kiểm tra nếu người dùng chọn '2' ---
    li t1, '2'                  # Tải ký tự mã ASCII của '2' vào t1
    beq t0, t1, exit_program    # Nếu t0 == t1 ('2'), nhảy đến nhãn exit_program để thoát

    # --- Xử lý khi nhập sai (Không phải '1' hoặc '2') ---
    la a0, msg_err              # Tải địa chỉ chuỗi thông báo lỗi nhập liệu vào a0
    li a7, 4                    # Gán mã dịch vụ ecall = 4 (In chuỗi ký tự)
    ecall                       # Thực hiện in thông báo lỗi lên màn hình mặc định
    j main                      # Nhảy không điều kiện quay lại nhãn main để hiện lại Menu

# =================================================================
# CHƯƠNG TRÌNH CON: BẮT ĐẦU VÀ QUẢN LÝ VÒNG LẶP THI
# =================================================================
start_quiz:
    # --- In thông báo chào mừng bắt đầu thi ---
    la a0, msg_welcome          # Tải địa chỉ chuỗi msg_welcome vào a0
    li a7, 4                    # Gán mã dịch vụ ecall = 4 (In chuỗi ký tự)
    ecall                       # Thực hiện in thông báo chào mừng

    # --- Khởi tạo các biến điều khiển vòng lặp thi ---
    li s0, 0                    # s0 = Chỉ số câu hỏi hiện tại (bắt đầu từ index = 0)
    lw s1, num_questions        # s1 = Load giá trị tổng số câu hỏi từ ô nhớ num_questions (20)
    li s2, 0                    # s2 = Số câu trả lời đúng (Khởi tạo điểm số bằng 0)

    # --- Gọi hàm trộn thứ tự câu hỏi ---
    jal ra, shuffle_questions   # Nhảy đến hàm shuffle_questions và lưu địa chỉ trả về vào ra

quiz_loop:
    beq s0, s1, quiz_end        # Nếu s0 == s1 (đã duyệt qua hết 20 câu), nhảy tới kết thúc quiz_end
    
    # --- Lấy địa chỉ của chuỗi văn bản câu hỏi hiện tại từ mảng ---
    la t0, questions_array      # Tải địa chỉ cơ sở của mảng câu hỏi questions_array vào t0
    slli t1, s0, 2              # t1 = s0 * 4 (Mỗi địa chỉ con trỏ trong mảng rộng 4 bytes - dịch trái 2 bit)
    add t0, t0, t1              # t0 = t0 + t1 (Tính địa chỉ tuyệt đối của phần tử thứ s0 trong mảng)
    lw a0, 0(t0)                # a0 = Đọc giá trị (địa chỉ chuỗi câu hỏi) từ ô nhớ t0 đang trỏ tới
    
    # --- Xuất câu hỏi ra MMIO Display thay vì console tiêu chuẩn ---
    jal ra, mmio_print_string   # Gọi hàm mmio_print_string để in nội dung câu hỏi ra MMIO

    # --- Thiết lập bộ đếm thời gian ngược (10 giây) ---
    li s3, 10                   # s3 = 10 (Biến lưu số giây đếm ngược còn lại cho câu hỏi hiện tại)
    
    mv a0, s3                   # Sao chép số giây s3 vào tham số a0
    jal ra, display_countdown   # Gọi hàm display_countdown để cập nhật số 10 lên LED 7 đoạn

input_countdown_loop:
    # --- Thăm dò (Polling) xem người dùng đã nhấn phím nào chưa ---
    li t0, MMIO_CTRL            # Tải địa chỉ thanh ghi điều khiển bàn phím vào t0
    lw t1, 0(t0)                # Đọc giá trị trạng thái từ địa chỉ MMIO_CTRL vào t1
    andi t1, t1, 1              # Lọc lấy bit cuối cùng (Bit Ready - bit 0 của Keyboard Control)
    bnez t1, process_input      # Nếu bit Ready != 0 (đã có phím bấm), nhảy đến xử lý ký tự process_input

    # --- Nếu chưa bấm phím: Thực hiện trì hoãn (Delay) 1 giây ---
    li a0, 1000                 # Tham số a0 = 1000 (thời gian tính bằng mili-giây: 1000ms = 1s)
    li a7, 32                   # Gán mã dịch vụ ecall = 32 (Hàm ngủ/trì hoãn - Sleep)
    ecall                       # Thực thi lệnh ngủ 1 giây
    
    addi s3, s3, -1             # Giảm biến đếm ngược thời gian đi 1 đơn vị (s3 = s3 - 1)
    mv a0, s3                   # Đưa số giây còn lại s3 vào tham số a0
    jal ra, display_countdown   # Gọi hàm hiển thị số giây còn lại lên bộ LED 7 đoạn
    bnez s3, input_countdown_loop # Nếu s3 != 0 (chưa hết 10 giây), lặp lại việc kiểm tra phím bấm

    # --- Trường hợp xử lý khi HẾT GIỜ (s3 == 0) ---
    la a0, msg_timeout          # Tải địa chỉ chuỗi thông báo hết giờ msg_timeout vào a0
    li a7, 4                    # Gán mã dịch vụ ecall = 4 (In chuỗi ký tự thông thường)
    ecall                       # In chuỗi báo hết giờ lên màn hình console
    j next_question             # Nhảy bỏ qua phần kiểm tra đáp án để chuyển thẳng sang câu tiếp theo

process_input:
    # --- Lấy ký tự vừa được gõ từ bộ đệm MMIO Bàn phím ---
    li t0, MMIO_DATA            # Tải địa chỉ thanh ghi dữ liệu bàn phím vào t0
    lw s4, 0(t0)                # Đọc mã ASCII của ký tự người dùng vừa nhập vào thanh ghi s4

check_valid:
    # --- Chuyển đổi phím số '1', '2', '3', '4' sang dạng ký tự chữ 'A', 'B', 'C', 'D' ---
    li t0, '1'                  # Tải mã ASCII ký tự '1' vào t0
    beq s4, t0, convert_A       # Nếu s4 == '1', nhảy đến nhãn convert_A

    li t0, '2'                  # Tải mã ASCII ký tự '2' vào t0
    beq s4, t0, convert_B       # Nếu s4 == '2', nhảy đến nhãn convert_B

    li t0, '3'                  # Tải mã ASCII ký tự '3' vào t0
    beq s4, t0, convert_C       # Nếu s4 == '3', nhảy đến nhãn convert_C

    li t0, '4'                  # Tải mã ASCII ký tự '4' vào t0
    beq s4, t0, convert_D       # Nếu s4 == '4', nhảy đến nhãn convert_D

    # --- Kiểm tra tính hợp lệ nếu người dùng nhập thẳng chữ cái ---
    li t0, 'A'                  # Tải mã ASCII ký tự 'A' vào t0
    blt s4, t0, invalid_input   # Nếu s4 < 'A' (Mã ASCII nhỏ hơn), nhảy đến báo lỗi nhập liệu invalid_input

    li t0, 'D'                  # Tải mã ASCII ký tự 'D' vào t0
    bgt s4, t0, invalid_input   # Nếu s4 > 'D' (Mã ASCII lớn hơn), nhảy đến báo lỗi nhập liệu invalid_input

    j compare_answer            # Nếu ký tự nằm trong khoảng ['A'..'D'], nhảy thẳng đến so sánh đáp án

convert_A:
    li s4, 'A'                  # Gán giá trị ký tự chữ 'A' vào thanh ghi s4
    j compare_answer            # Nhảy tiếp đến phần so sánh đáp án

convert_B:
    li s4, 'B'                  # Gán giá trị ký tự chữ 'B' vào thanh ghi s4
    j compare_answer            # Nhảy tiếp đến phần so sánh đáp án

convert_C:
    li s4, 'C'                  # Gán giá trị ký tự chữ 'C' vào thanh ghi s4
    j compare_answer            # Nhảy tiếp đến phần so sánh đáp án

convert_D:
    li s4, 'D'                  # Gán giá trị ký tự chữ 'D' vào thanh ghi s4
    j compare_answer            # Nhảy tiếp đến phần so sánh đáp án

invalid_input:
    # --- Thông báo lỗi khi người dùng bấm phím không hợp lệ ---
    la a0, msg_err              # Tải địa chỉ chuỗi thông báo nhập sai msg_err vào a0
    li a7, 4                    # Gán mã dịch vụ ecall = 4 (In chuỗi ký tự thông thường)
    ecall                       # Thực hiện lệnh in thông báo lỗi nhập liệu lên console
    j input_countdown_loop      # Quay trở lại vòng lặp chờ gõ phím tiếp (giữ nguyên thời gian đếm ngược)

compare_answer:
    # --- Lấy nội dung đáp án đúng thực tế của câu hỏi hiện tại ---
    la t0, answers_array        # Tải địa chỉ cơ sở của mảng đáp án answers_array vào t0
    add t0, t0, s0              # t0 = t0 + s0 (Do mỗi phần tử đáp án chỉ rộng 1 byte nên không cần nhân dịch bit)
    lbu s5, 0(t0)               # Đọc 1 byte không dấu (đáp án đúng thực tế) từ địa chỉ t0 lưu vào s5

    beq s4, s5, answer_correct  # So sánh: Nếu s4 (bấm) == s5 (đáp án đúng), nhảy đến phần xử lý đúng câu hỏi

    # --- TRƯỜNG HỢP TRẢ LỜI SAI ---
    la a0, msg_wrong            # Tải địa chỉ chuỗi thông báo trả lời sai msg_wrong vào a0
    jal ra, mmio_print_string   # Xuất chuỗi thông báo sai ra MMIO Display Tool
    
    # --- In ký tự chữ cái đáp án đúng thực tế kế tiếp ---
    mv a0, s5                   # Đưa mã ký tự đáp án đúng trong s5 vào tham số a0
    jal ra, mmio_print_char     # Xuất ký tự đáp án đúng đó ra màn hình MMIO Display
    la a0, newline              # Tải địa chỉ chuỗi xuống dòng newline vào a0
    jal ra, mmio_print_string   # Xuất lệnh xuống dòng ra MMIO Display
    
    la a0, newline              # Tiếp tục tải chuỗi xuống dòng tạo khoảng cách
    jal ra, mmio_print_string   # Xuất chuỗi xuống dòng ra MMIO Display
    
    j next_question             # Nhảy đến nhãn xử lý để chuyển sang câu tiếp theo
    
answer_correct:
    # --- TRƯỜNG HỢP TRẢ LỜI ĐÚNG ---
    la a0, msg_correct          # Tải địa chỉ chuỗi thông báo chúc mừng msg_correct vào a0
    jal ra, mmio_print_string   # Xuất chuỗi chúc mừng ra màn hình MMIO Display
    addi s2, s2, 1              # Tăng biến đếm tổng số câu trả lời đúng lên 1 đơn vị (s2 = s2 + 1)

next_question:
    # --- Tắt/Xóa nội dung hiển thị trên 2 đèn LED 7 đoạn trước khi qua câu mới ---
    li t0, DIGIT_LEFT           # Tải địa chỉ thanh ghi LED trái vào t0
    sb zero, 0(t0)              # Ghi giá trị 0 (tắt hết các đoạn LED) vào địa chỉ LED trái

    li t0, DIGIT_RIGHT          # Tải địa chỉ thanh ghi LED phải vào t0
    sb zero, 0(t0)              # Ghi giá trị 0 (tắt hết các đoạn LED) vào địa chỉ LED phải

    addi s0, s0, 1              # Tăng chỉ số câu hỏi hiện tại lên 1 để chuẩn bị (s0 = s0 + 1)
    j quiz_loop                 # Quay trở lại đầu vòng lặp thi để load câu hỏi tiếp theo

quiz_end:
    # --- HIỂN THỊ TỔNG KẾT KẾT QUẢ ĐIỂM THI ---
    la a0, msg_result           # Tải địa chỉ chuỗi tiêu đề kết quả msg_result vào a0
    jal ra, mmio_print_string   # Xuất chuỗi tiêu đề kết quả ra MMIO Display
    
    la a0, msg_score            # Tải địa chỉ chuỗi thông báo số câu đúng msg_score vào a0
    jal ra, mmio_print_string   # Xuất chuỗi "So cau dung: " ra MMIO Display
    
    mv a0, s2                   # Đưa giá trị điểm số (số câu đúng) s2 vào tham số a0
    jal ra, mmio_print_int      # Gọi hàm mmio_print_int để chuyển số và in ra MMIO Display
    
    la a0, msg_total            # Tải địa chỉ chuỗi ký tự phân tách dấu xuyệt " / "
    jal ra, mmio_print_string   # Xuất chuỗi dấu xuyệt phân tách ra MMIO Display
    
    lw a0, num_questions        # Đọc giá trị tổng số lượng câu hỏi từ ô nhớ vào tham số a0
    jal ra, mmio_print_int      # Gọi hàm in số nguyên xuất tổng số câu hỏi ra MMIO Display
    
    la a0, newline              # Tải địa chỉ chuỗi ký tự xuống dòng newline vào a0
    jal ra, mmio_print_string   # Xuất chuỗi xuống dòng hoàn tất dòng kết quả
    
    j main                      # Vòng lặp vô hạn: Quay trở lại Menu chính ban đầu chứ không tắt hẳn

